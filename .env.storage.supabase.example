# ==========================================
# Supabase Storage Configuration
# ==========================================
# Use Supabase for authentication and S3-compatible object storage.
# Copy to .env.storage.supabase and generate required secrets.
#
# Usage (local development):
#   cp .env.storage.supabase.example .env.storage.supabase
#   set -a && source .env && source .env.local && source .env.storage.supabase && set +a
#
# Usage (Docker Compose):
#   cp .env.storage.supabase.example .env.storage.supabase
#   docker compose --env-file .env --env-file .env.docker --env-file .env.storage.supabase up
#
# Generate secrets with:
#   openssl rand -base64 32  # For passwords and keys
#   # For JWT secrets and keys, see Supabase documentation
# ==========================================

# ==========================================
# Storage Backend
# ==========================================

STORAGE_TYPE=s3
S3_REGION=local
S3_BUCKET_NAME=copilot-ld

# ==========================================
# Database
# ==========================================

SUPABASE_DB_PASSWORD=your_database_password

# ==========================================
# JWT Configuration
# ==========================================
# Shared by Auth and Storage services.

SUPABASE_JWT_SECRET=your_jwt_secret_at_least_32_characters

# ==========================================
# Auth Service Keys
# ==========================================
# Generate using Supabase JWT generator or manually create JWTs.

SUPABASE_ANON_KEY=your_anon_key_jwt
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_jwt

# ==========================================
# Auth Settings
# ==========================================

SUPABASE_SITE_URL=http://localhost:3000
SUPABASE_DISABLE_SIGNUP=false

# Enable JWT authentication in web extension
EXTENSION_WEB_AUTH_ENABLED=true

# ==========================================
# Storage S3 Protocol Credentials
# ==========================================
# Used by services to access Supabase Storage via S3 protocol.

SUPABASE_S3_ACCESS_KEY=your_s3_access_key
SUPABASE_S3_SECRET_KEY=your_s3_secret_key

# AWS SDK credentials (references Supabase S3 credentials)
AWS_ACCESS_KEY_ID=your_s3_access_key
AWS_SECRET_ACCESS_KEY=your_s3_secret_key

# ==========================================
# Optional: SMTP Configuration
# ==========================================
# Leave empty to use email autoconfirm (development only).

# SUPABASE_SMTP_HOST=
# SUPABASE_SMTP_PORT=587
# SUPABASE_SMTP_USER=
# SUPABASE_SMTP_PASS=
