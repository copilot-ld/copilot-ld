{
  "service": {
    "agent": {
      "assistant": "common.Assistant.software-dev-expert",
      "threshold": 0.25,
      "limit": 100,
      "temperature": 0.25,
      "budget": {
        "tokens": 90000,
        "allocation": {
          "tools": 0.1,
          "history": 0.1,
          "context": 0.6
        }
      }
    },
    "llm": {
      "model": "gpt-5"
    },
    "memory": {
      "alwaysLoadTools": [
        "get_ontology",
        "query_by_descriptor",
        "query_by_content",
        "query_by_pattern"
      ]
    },
    "tool": {
      "endpoints": {
        "get_ontology": {
          "method": "graph.Graph.GetOntology",
          "request": "graph.GetOntologyRequest"
        },
        "query_by_pattern": {
          "method": "graph.Graph.QueryByPattern",
          "request": "graph.Pattern"
        },
        "query_by_content": {
          "method": "vector.Vector.QueryByContent",
          "request": "vector.QueryByTextRequest"
        },
        "query_by_descriptor": {
          "method": "vector.Vector.QueryByDescriptor",
          "request": "vector.QueryByTextRequest"
        },
        "sha256_hash": {
          "method": "hash.Hash.Sha256",
          "request": "hash.HashRequest"
        },
        "md5_hash": {
          "method": "hash.Hash.Md5",
          "request": "hash.HashRequest"
        }
      }
    }
  }
}
