# ==========================================
# MinIO Storage Configuration
# ==========================================
# Use MinIO for S3-compatible object storage.
# Copy to .env.storage.minio and fill in passwords.
#
# Usage (local development):
#   cp .env.storage.minio.example .env.storage.minio
#   set -a && source .env && source .env.local && source .env.storage.minio && set +a
#
# Usage (Docker Compose):
#   cp .env.storage.minio.example .env.storage.minio
#   docker compose --env-file .env --env-file .env.docker --env-file .env.storage.minio up
# ==========================================

# ==========================================
# Storage Backend
# ==========================================

STORAGE_TYPE=s3
S3_REGION=us-east-1
S3_BUCKET_NAME=copilot-ld

# ==========================================
# MinIO Server Configuration
# ==========================================

MINIO_ENDPOINT=http://storage.copilot-ld.local:9000
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=choose_a_secure_password

# ==========================================
# AWS SDK Credentials (MinIO-compatible)
# ==========================================
# These credentials are used by services to access MinIO via AWS SDK.
# Must match MINIO_ROOT_USER and MINIO_ROOT_PASSWORD.

AWS_ACCESS_KEY_ID=admin
AWS_SECRET_ACCESS_KEY=choose_a_secure_password
