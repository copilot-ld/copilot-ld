# ==========================================
# Docker Compose Configuration
# ==========================================
# Proxy and networking configuration for Docker Compose deployments.
# Copy to .env.docker when using docker compose.
#
# Usage:
#   cp .env.docker.example .env.docker
#   docker compose --env-file .env --env-file .env.docker up
#
# Note: Do NOT set SERVICE_*_HOST or EXTENSION_*_HOST variables.
# Docker containers use internal DNS for service discovery.
# ==========================================

# ==========================================
# Proxy Configuration
# ==========================================
# Required for containers to access external APIs through the gateway.

HTTPS_PROXY=http://gateway.copilot-ld.local:3128
HTTP_PROXY=http://gateway.copilot-ld.local:3128
NO_PROXY=localhost,127.0.0.1,*.copilot-ld.local
