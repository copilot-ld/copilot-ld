# ==========================================
# Local Development Configuration
# ==========================================
# Service networking for local development (services run on localhost).
# Copy to .env.local when running services directly (not via Docker).
#
# Usage:
#   cp .env.local.example .env.local
#   set -a && source .env && source .env.local && set +a
#   npm run dev
#
# Note: Do NOT load this file when using Docker Compose.
# Docker containers use internal DNS for service discovery.
# ==========================================

# ==========================================
# Extension Services
# ==========================================

EXTENSION_UI_HOST=localhost
EXTENSION_UI_PORT=3000

EXTENSION_WEB_HOST=localhost
EXTENSION_WEB_PORT=3001
EXTENSION_WEB_URL=http://localhost:3001/web/api

# ==========================================
# Core Services
# ==========================================

SERVICE_AGENT_HOST=localhost
SERVICE_AGENT_PORT=3002

SERVICE_MEMORY_HOST=localhost
SERVICE_MEMORY_PORT=3003

SERVICE_LLM_HOST=localhost
SERVICE_LLM_PORT=3004

SERVICE_VECTOR_HOST=localhost
SERVICE_VECTOR_PORT=3005

SERVICE_GRAPH_HOST=localhost
SERVICE_GRAPH_PORT=3006

SERVICE_TOOL_HOST=localhost
SERVICE_TOOL_PORT=3007

SERVICE_TRACE_HOST=localhost
SERVICE_TRACE_PORT=3008

# ==========================================
# Optional: API Extension
# ==========================================

# EXTENSION_API_PORT=3979
# EXTENSION_API_SECRET=your_api_secret

# ==========================================
# Optional: Teams Extension
# ==========================================

# EXTENSION_TEAMSAPP_BOT_ID=copilot-ld
# EXTENSION_TEAMSAPP_BOT_DOMAIN=your_domain
# EXTENSION_TEAMSAPP_APP_PORT=3978
# EXTENSION_TEAMSAPP_MASTER_KEY=your_master_key
# EXTENSION_TEAMSAPP_MICROSOFT_APP_TYPE=SingleTenant
# EXTENSION_TEAMSAPP_MICROSOFT_APP_TENANT_ID=your_tenant_id
# EXTENSION_TEAMSAPP_MICROSOFT_APP_ID=your_app_id
# EXTENSION_TEAMSAPP_MICROSOFT_APP_PASSWORD=your_app_password

# ==========================================
# Optional: Example Tool Service
# ==========================================

# SERVICE_HASH_HOST=localhost
# SERVICE_HASH_PORT=3009
