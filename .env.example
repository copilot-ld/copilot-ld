# ==========================================
# Base Configuration
# ==========================================
# Core secrets and API credentials required for all deployment modes.
# Copy to .env and fill in values.
#
# This file contains only base configuration. For complete setup, also use:
#   - .env.local.example     → Local development networking
#   - .env.docker.example    → Docker Compose proxy settings
#   - .env.storage.*.example → Storage backend configuration
#
# See docs/configuration.md for complete documentation.
# ==========================================

# ==========================================
# API Credentials (Required)
# ==========================================

# LLM API access token (required for all operations)
# LLM_TOKEN=your_llm_api_token

# LLM API base URL (optional, defaults to GitHub Copilot API)
# LLM_BASE_URL=https://api.githubcopilot.com

# GitHub token for repository operations
# GITHUB_TOKEN=your_github_token

# GitHub OAuth client ID (20-character string)
# GITHUB_CLIENT_ID=your_client_id_here

# ==========================================
# Service Authentication (Required)
# ==========================================

# HMAC secret for inter-service authentication (32-character string)
# Generate with: node scripts/secret.js
# SERVICE_SECRET=your_generated_secret_here

# JWT secret for extension authentication (HS256 signing key)
# JWT_SECRET=your_hs256_signing_secret

# ==========================================
# Debug (Optional)
# ==========================================

# Enable debug logging for all components
# DEBUG=*

# Or enable for specific components
# DEBUG=agent,memory