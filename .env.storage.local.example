# ==========================================
# Local Storage Configuration
# ==========================================
# Use local filesystem for data persistence.
# This is the default storage mode - no configuration required.
#
# Usage (local development):
#   set -a && source .env && source .env.local && source .env.storage.local && set +a
#
# Usage (Docker Compose):
#   docker compose --env-file .env --env-file .env.docker --env-file .env.storage.local up
# ==========================================

STORAGE_TYPE=local
